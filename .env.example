# SMTP for inquiry form (nodemailer in app/api/contact/route.ts)
# Use the underlying Google Workspace account, not the alias.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# From-address for outbound mail (Workspace alias once provisioned).
SMTP_FROM="Bootleggers Landing <experience@bootleggerslanding.com>"

# Where internal inquiry notifications go.
CONTACT_EMAIL=experience@bootleggerslanding.com

# GA4 measurement ID (set after creating the new sibling property).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL (used for canonical, sitemap, OG).
NEXT_PUBLIC_SITE_URL=https://bootleggerslanding.com
